# Copy to .env and fill in your values
# cp .env.example .env

# REQUIRED: Anthropic API key for Claude (the chatbot LLM)
ANTHROPIC_API_KEY=sk-ant-...

# REQUIRED: Your email for SEC EDGAR User-Agent header (SEC requires identification)
SEC_USER_AGENT_EMAIL=your.email@example.com

# OPTIONAL: override embedding model (default: all-MiniLM-L6-v2 — free, runs on CPU)
# EMBEDDING_MODEL=all-MiniLM-L6-v2
